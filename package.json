{
  "name": "ai-developer-kit",
  "version": "1.4.39",
  "type": "module",
  "description": "Strict project template for automated setup and code quality.",
  "main": "index.js",
  "scripts": {
    "test:meta": "vitest run tests/meta --reporter=verbose",
    "test:unit": "vitest run tests/unit --coverage --reporter=verbose",
    "test:e2e": "vitest run tests/e2e --reporter=verbose",
    "test": "pnpm test:meta && pnpm test:unit && pnpm test:e2e",
    "build": "tsc",
    "start": "node dist/index.js || echo 'No entry point configured'",
    "audit": "pnpm audit --prod",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mdlint": "markdownlint .",
    "check-version": "node .integrity-suite/scripts/check-version.js",
    "check-changelog": "node .integrity-suite/scripts/check-changelog.js",
    "validate-project": "pnpm lint && pnpm mdlint && pnpm format:check && tsc --noEmit && pnpm audit && pnpm check-version && pnpm check-changelog && pnpm test",
    "prepare": "husky"
  },
  "author": "Marc Galindo (marcundertest) - https://marcundertest.com",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.18.0",
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint --fix",
      "prettier --write"
    ],
    "*.{js,json,css}": [
      "prettier --write"
    ]
  }
}
